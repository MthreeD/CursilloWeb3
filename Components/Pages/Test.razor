@page "/test"
@rendermode InteractiveServer
@using CursilloWeb.Data
@using Microsoft.EntityFrameworkCore
@using DevExpress.Blazor.RichEdit
@using System.Drawing

@inject ApplicationDbContext DbContext
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Test Page Edit</PageTitle>

<div class="full-page-breakout">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Test Page Edit</h2>
        <div class="d-flex align-items-center" style="gap: 10px">
            @if (!IsLoading)
            {
                <DxButton Text="Save" 
                          RenderStyle="ButtonRenderStyle.Primary"
                          Click="@SaveTest"
                          Enabled="@(!IsSaving)" />

                @if (IsSaving)
                {
                    <DxButton RenderStyle="ButtonRenderStyle.Secondary"
                              Enabled="false">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            Saving...
                    </DxButton>
                }
            }
            <DxButton Text="Back to Home" 
                      CssClass="btn btn-outline-primary"
                      Click="@NavigateToHome" />
        </div>
    </div>

    @if (IsLoading)
    {
        <DxLoadingPanel Visible="true" />
    }
    else
    {
        <div class="mb-3 d-flex justify-content-center">
            <div style="width: 100%;">
                <!-- Inline Controls Section -->
                <div class="d-flex align-items-start gap-4 mb-4">
                    <!-- Background Color Section -->
                    <div class="flex-shrink-0">
                        <label class="form-label fw-bold">Background Color:</label>
                        <div style="width: 240px;">
                            <DxDropDownBox @bind-Value="@ColorValue"
                                           QueryDisplayText="@QueryText"
                                           NullText="Select color..."
                                           CssClass="w-100">
                                <DropDownBodyTemplate Context="dropDownContext">
                                    <DxColorPalette Value="@GetColorDropDownValue(dropDownContext.DropDownBox)"
                                                    ValueChanged="@((string value) => ColorDropDownValueChanged(value, dropDownContext.DropDownBox))"
                                                    CssClass="dropdown-template-color-palette" />
                                </DropDownBodyTemplate>
                                <EditBoxDisplayTemplate Context="editBoxContext">
                                    <div class="template-container">
                                        <span class="dropdown-icon-color" style="background-color: @ColorValue;"></span>
                                        <DxInputBox/>
                                    </div>
                                </EditBoxDisplayTemplate>
                            </DxDropDownBox>
                        </div>
                    </div>

                    <!-- Font Images Section -->
                    <div class="flex-shrink-0">
                        <label class="form-label fw-bold">Font Images:</label>
                        <div style="width: 240px;">
                            <DxButton Text="Font Images" 
                                      RenderStyle="ButtonRenderStyle.Info"
                                      IconCssClass="dx-icon-font"
                                      Click="@ShowFontImagesPopup"
                                      CssClass="w-100" />
                        </div>
                    </div>

                    <!-- Saved Font Name -->
                    <div class="flex-shrink-0">
                        <label class="form-label fw-bold">Saved Font Name:</label>
                        <div style="width: 200px;">
                            <DxTextBox @ref="savedFontName"
                                       @bind-Text="@CurrentTest.FontName"
                                       CssClass="w-100"
                                       Placeholder="Font Name..." />
                        </div>
                    </div>

                    <!-- Saved Font Size -->
                    <div class="flex-shrink-0">
                        <label class="form-label fw-bold">Saved Font Size:</label>
                        <div style="width: 120px;">
                            <DxTextBox @ref="savedFontSize"
                                       @bind-Text="@CurrentTest.FontSize"
                                       CssClass="w-100"
                                       Placeholder="Font Size..." />
                        </div>
                    </div>
                </div>

                <!-- RTF Text Input Section -->
                <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
                    <DxFormLayoutItem Caption="RTF Text Input:" ColSpanMd="12">
                        <Template>
                            <div style="margin-left: -10px; margin-right: -10px; width: calc(100% + 20px); border-top: 1px solid #ccc; border-bottom: 1px solid #ccc; box-sizing: border-box;">
                                <DxRichEdit @ref="rtfTextInput"
                                            DocumentContent="@documentContent"
                                            DocumentContentChanged="@OnDocumentContentChanged"
                                            SelectionChanged="@OnSelectionChanged"
                                            CustomizeRibbon="@OnCustomizeRibbon"
                                            CssClass="w-100 header-size-editor"
                                            DocumentFormat="DocumentFormat.OpenXml"
                                            ReadOnly="false"
                                            BarMode="BarMode.Ribbon" />
                            </div>
                        </Template>
                    </DxFormLayoutItem>
                </DxFormLayout>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Message))
        {
            <div class="mt-3">
                <div class="alert @(IsError ? "alert-danger" : "alert-success")" role="alert">
                    @Message
                    <button type="button" class="btn-close" data-bs-dismiss="alert" @onclick="@(() => Message = string.Empty)"></button>
                </div>
            </div>
        }
    }
</div>

<!-- Font Images Popup -->
<DxPopup @bind-Visible="@FontImagesPopupVisible"
         HeaderText="Font Images Gallery"
         Width="900"
         Height="600"
         ShowCloseButton="true"
         AllowResize="true"
         AllowDrag="true"
         ShowFooter="false"
         CssClass="font-images-popup"
         VerticalAlignment="VerticalAlignment.Center"
         HorizontalAlignment="HorizontalAlignment.Center">
    <BodyTemplate>
        <div class="p-3 text-center">
            <!-- Display only the FontImages.png image -->
            <img src="images/Pictures/FontImages.png" 
                 alt="Font Images Reference" 
                 class="img-fluid font-reference-image"
                 style="max-width: 100%; max-height: 100%; object-fit: contain; border: 1px solid #ddd; border-radius: 5px;"
                 onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
            <div style="display: none; padding: 40px; border: 2px dashed #ccc; border-radius: 5px; background-color: #f8f9fa;">
                <i class="dx-icon-image" style="font-size: 48px; color: #ccc;"></i>
                <p class="text-muted mt-2 mb-0">
                    Place your <strong>FontImages.png</strong> file in:<br>
                    <code>wwwroot/images/Pictures/FontImages.png</code>
                </p>
            </div>
        </div>
    </BodyTemplate>
</DxPopup>

<style>
    /* Force page height to fit window without vertical overflow */
    body {
        overflow: hidden !important; /* user requested NO scrollbars */
    }

    .full-page-breakout {
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        padding-left: 10px;
        padding-right: 10px;
        box-sizing: border-box;
    }

    .header-size-editor .dxbl-richedit {
        height: 120px !important;
        min-height: 120px !important;
    }

    .header-size-editor .dxbl-richedit-content {
        background-color: @ColorValue !important;
        font-family: 'Segoe UI Light', sans-serif !important;
        font-size: 12pt !important;
    }

    /* Set default font for new content */
    .header-size-editor .dxbl-richedit-content p,
    .header-size-editor .dxbl-richedit-content div,
    .header-size-editor .dxbl-richedit-content span {
        font-family: 'Segoe UI Light', sans-serif;
        font-size: 12pt;
    }

    .dropdown-template-color-palette {
        border-width: 0px;
    }

    /* Font Images Popup Styling */
    .font-images-popup .dx-popup-content {
        padding: 0;
        height: 100%;
        overflow: hidden;
    }

    .font-images-popup .dx-popup-header {
        cursor: move;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-bottom: 2px solid #dee2e6;
    }

    .font-images-popup .dx-popup-header:hover {
        background: linear-gradient(135deg, #e9ecef 0%, #dee2e6 100%);
    }

    .font-reference-image {
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        max-height: calc(100vh - 200px) !important;
    }

    /* Inline controls styling */
    .form-label.fw-bold {
        font-weight: 600;
        margin-bottom: 8px;
        color: #333;
    }
</style>

<script>
    window.resizeSvgImages = () => {
        try {
            // Find all images in the RichEdit content area
            const richEditContent = document.querySelector('.dxbl-richedit-content, .dx-richedit-content');
            if (richEditContent) {
                const images = richEditContent.querySelectorAll('img');

                images.forEach(img => {
                    // Check if the image source ends with .svg
                    const src = img.src || img.getAttribute('src') || '';
                    if (src.toLowerCase().endsWith('.svg')) {
                        // Set width to 1 inch (96 pixels at standard DPI)
                        img.style.width = '96px';
                        img.setAttribute('width', '96');

                        console.log('Resized SVG image to 1 inch width:', src);
                    }
                });
            }
        } catch (e) {
            console.error('Error resizing SVG images:', e);
        }
    };
</script>

@code {
    // Static list to load fonts once and persist them for the session
    private static readonly List<string> SystemFonts = FontFamily.Families
        .Select(f => f.Name)
        .OrderBy(n => n)
        .ToList();

    private CursilloWeb.Data.Test CurrentTest = new CursilloWeb.Data.Test();
    private bool IsLoading = false;
    private bool IsSaving = false;
    private string Message = string.Empty;
    private bool IsError = false;
    private bool FontImagesPopupVisible = false;
    private DxRichEdit? rtfTextInput;
    private DxTextBox? savedFontName;
    private DxTextBox? savedFontSize;
    private byte[]? documentContent;
    private bool _isUpdatingFont = false;
    private bool _isUpdatingFontSize = false;
    private bool _isCustomizingToolbar = false;

    private object ColorValue
    { 
        get => !string.IsNullOrEmpty(CurrentTest.TextBoxText) ? CurrentTest.TextBoxText : "#66CDFF";
        set => CurrentTest.TextBoxText = value?.ToString();
    }

    void OnCustomizeRibbon(IRibbon ribbon)
    {
        // Prevent recursive ribbon customization
        if (_isCustomizingToolbar) return;

        try
        {
            _isCustomizingToolbar = true;

            // Access the Home tab's Font group
            var homeTab = ribbon.Tabs[RichEditRibbonTabNames.Home];
            var fontGroup = homeTab.Groups[RichEditRibbonGroupNames.HomeFont];

            // 1. Remove the default Font Name selector
            fontGroup.Items.Remove(RichEditBarItemNames.FontName);

            // 2. Add the custom Font Name ComboBox
            var customFontCombo = fontGroup.Items.AddCustomComboBox(
                0,
                () => CurrentTest.FontName ?? "Segoe UI Light",
                async (newFontValue) =>
                {
                    // Prevent recursive updates
                    if (_isUpdatingFont) return;

                    try
                    {
                        _isUpdatingFont = true;
                        var newFont = newFontValue?.ToString() ?? "Segoe UI Light";

                        // Only update if value actually changed
                        if (CurrentTest.FontName != newFont)
                        {
                            CurrentTest.FontName = newFont;

                            // Defer StateHasChanged to avoid interrupting the combo box interaction
                            await Task.Delay(50);
                            await InvokeAsync(() => StateHasChanged());
                        }
                    }
                    finally
                    {
                        _isUpdatingFont = false;
                    }
                }
            );

            // 3. Populate with the pre-loaded system fonts
            foreach (var font in SystemFonts)
            {
                customFontCombo.Items.Add(font, font);
            }

            // 4. Remove the default Font Size selector
            fontGroup.Items.Remove(RichEditBarItemNames.FontSize);

            // 5. Add the custom Font Size ComboBox
            var customFontSizeCombo = fontGroup.Items.AddCustomComboBox(
                2, // Position after font name
                () => CurrentTest.FontSize ?? "12",
                async (newSizeValue) =>
                {
                    // Prevent recursive updates
                    if (_isUpdatingFontSize) return;

                    try
                    {
                        _isUpdatingFontSize = true;
                        var newSize = newSizeValue?.ToString() ?? "12";

                        // Only update if value actually changed
                        if (CurrentTest.FontSize != newSize)
                        {
                            CurrentTest.FontSize = newSize;

                            // Defer StateHasChanged to avoid interrupting the combo box interaction
                            await Task.Delay(50);
                            await InvokeAsync(() => StateHasChanged());
                        }
                    }
                    finally
                    {
                        _isUpdatingFontSize = false;
                    }
                }
            );

            // 6. Populate with common font sizes
            var fontSizes = new[] { "8", "9", "10", "11", "12", "14", "16", "18", "20", "22", "24", "26", "28", "36", "48", "72" };
            foreach (var size in fontSizes)
            {
                customFontSizeCombo.Items.Add(size, size);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error customizing ribbon: {ex.Message}");
        }
        finally
        {
            _isCustomizingToolbar = false;
        }
    }

    string GetColorDropDownValue(IDropDownBox dropDownBox) {
        return dropDownBox.Value as string ?? "#66CDFF";
    }

    void ColorDropDownValueChanged(string value, IDropDownBox dropDownBox) {
        dropDownBox.BeginUpdate();
        dropDownBox.Value = value;
        ColorValue = value;
        dropDownBox.DropDownVisible = false;
        dropDownBox.EndUpdate();
    }

    string QueryText(DropDownBoxQueryDisplayTextContext arg) {
        return arg.Value as string ?? "";
    }

    protected override async Task OnInitializedAsync()
    {
        // Load existing test data if any
        await LoadTest();
    }

    private void ShowFontImagesPopup()
    {
        FontImagesPopupVisible = true;
    }

    private async Task LoadTest()
    {
        try
        {
            IsLoading = true;
            var existingTest = await DbContext.Tests.FirstOrDefaultAsync();
            if (existingTest != null)
            {
                CurrentTest = existingTest;

                // Load document content if exists (stored as base64 string in HtmlTest)
                if (!string.IsNullOrEmpty(CurrentTest.HtmlTest))
                {
                    try
                    {
                        documentContent = Convert.FromBase64String(CurrentTest.HtmlTest);
                    }
                    catch
                    {
                        // If conversion fails, initialize empty document
                        documentContent = null;
                    }
                }
            }

            // Initialize default font values if not set
            if (string.IsNullOrEmpty(CurrentTest.FontName))
            {
                CurrentTest.FontName = "Segoe UI Light";
            }
            if (string.IsNullOrEmpty(CurrentTest.FontSize))
            {
                CurrentTest.FontSize = "12";
            }
        }
        catch (Exception ex)
        {
            Message = $"Error loading test data: {ex.Message}";
            IsError = true;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void OnDocumentContentChanged(byte[] content)
    {
        documentContent = content;

        // Store as base64 string in HtmlTest field
        if (content != null && content.Length > 0)
        {
            CurrentTest.HtmlTest = Convert.ToBase64String(content);

            // Process SVG images after document changes
            _ = ProcessSvgImagesAsync();
        }
        else
        {
            CurrentTest.HtmlTest = string.Empty;
        }
    }

    private async Task ProcessSvgImagesAsync()
    {
        if (rtfTextInput == null) return;

        try
        {
            // Small delay to ensure document is fully rendered in DOM
            await Task.Delay(200);

            // Call JavaScript to find and resize SVG images
            await JSRuntime.InvokeVoidAsync("resizeSvgImages");

            Console.WriteLine("SVG image processing completed");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error processing SVG images: {ex.Message}");
        }
    }

    private void OnSelectionChanged()
    {
        // Don't call StateHasChanged - it triggers excessive re-renders
        // The text boxes are bound to CurrentTest properties and will update automatically
    }

    private async Task SaveTest()
    {
        try
        {
            IsSaving = true;
            Message = string.Empty;

            if (CurrentTest.Id == Guid.Empty)
            {
                // New test entry
                CurrentTest.Id = Guid.NewGuid();
                CurrentTest.CreatedAt = DateTime.Now;
                CurrentTest.LastUpdated = DateTime.Now;
                DbContext.Tests.Add(CurrentTest);
            }
            else
            {
                // Update existing - ensure entity is properly tracked
                CurrentTest.LastUpdated = DateTime.Now;

                // Check if entity is already tracked
                var existingEntry = DbContext.ChangeTracker.Entries<CursilloWeb.Data.Test>()
                    .FirstOrDefault(e => e.Entity.Id == CurrentTest.Id);

                if (existingEntry == null)
                {
                    // Entity not tracked, attach and mark as modified
                    DbContext.Tests.Attach(CurrentTest);
                    DbContext.Entry(CurrentTest).State = EntityState.Modified;
                }
                else
                {
                    // Entity already tracked, update its properties
                    existingEntry.Entity.TextBoxText = CurrentTest.TextBoxText;
                    existingEntry.Entity.HtmlTest = CurrentTest.HtmlTest;
                    existingEntry.Entity.FontName = CurrentTest.FontName;
                    existingEntry.Entity.FontSize = CurrentTest.FontSize;
                    existingEntry.Entity.LastUpdated = CurrentTest.LastUpdated;
                }
            }

            await DbContext.SaveChangesAsync();

            // Reload the entity to ensure we have the latest version from the database
            await DbContext.Entry(CurrentTest).ReloadAsync();

            // Refresh the document content binding from the saved entity
            if (!string.IsNullOrEmpty(CurrentTest.HtmlTest))
            {
                try
                {
                    documentContent = Convert.FromBase64String(CurrentTest.HtmlTest);
                }
                catch
                {
                    documentContent = null;
                }
            }
            else
            {
                documentContent = null;
            }

            Message = "Test data saved successfully!";
            IsError = false;

            Console.WriteLine($"Saved: FontName={CurrentTest.FontName}, FontSize={CurrentTest.FontSize}, HtmlTest length={CurrentTest.HtmlTest?.Length ?? 0}");

            // Force UI refresh to update the RichEdit binding
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Message = $"Error saving test data: {ex.Message}";
            IsError = true;
            Console.WriteLine($"Save error: {ex.Message}");
            Console.WriteLine($"Stack trace: {ex.StackTrace}");
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void NavigateToHome()
    {
        Navigation.NavigateTo("/");
    }
}