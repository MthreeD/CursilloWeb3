@page "/article/{Id:guid}"
@rendermode InteractiveServer
@inject CursilloWeb.Services.ArticleService ArticleService
@inject NavigationManager Navigation
@using CursilloWeb.Data
@* @using DevExpress.Blazor *@

<PageTitle>@(Article?.Title ?? "Article") - Cursillo</PageTitle>

<div class="container article-details">
    @if (IsLoading)
    {
        <div class="text-center py-5">
            <DxLoadingPanel Visible="true" />
        </div>
    }
    else if (Article == null)
    {
        <div class="alert alert-warning my-4" role="alert">
            <h4 class="alert-heading"><i class="bi bi-exclamation-triangle me-2"></i>Article Not Found</h4>
            <p>Article not found. <a href="/" class="alert-link">Return to Home</a></p>
        </div>
    }
    else
    {
        <div class="card my-4 border-0 shadow-sm">
            <div class="card-header bg-white pb-0 border-0">
                <h1 class="display-4 text-primary mb-3">@Article.Title</h1>
                <div class="text-muted pb-3">
                    <i class="bi bi-calendar me-2"></i> @Article.CreatedDate.ToLongDateString()
                </div>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Article.ImageUrl))
                {
                    <div class="mb-4 text-center">
                        <img src="@Article.ImageUrl" 
                             alt="@Article.Title" 
                             class="img-fluid rounded" 
                             style="max-height: 500px;" />
                    </div>
                }

                <div class="article-content fs-5" style="line-height: 1.8;">
                    @((MarkupString)Article.Content)
                </div>

                <hr class="my-5" />

                <div class="text-center">
                    <DxButton Text="Back to Home" 
                              RenderStyle="ButtonRenderStyle.Secondary" 
                              NavigateUrl="/" 
                              IconCssClass="bi bi-arrow-left" />
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private Article? Article;
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        Article = await ArticleService.GetArticleByIdAsync(Id);
        IsLoading = false;
        
        if (Article != null && !Article.IsVisible)
        {
            // If not visible, simulate not found (or allow admin to see it?)
            // For now, strictly hide.
            Article = null;
        }
    }
}
