@page "/article/{Id:int}"
@inject CursilloWeb.Services.ArticleService ArticleService
@inject NavigationManager Navigation
@using CursilloWeb.Data

<PageTitle>@(Article?.Title ?? "Article") - Cursillo</PageTitle>

<div class="container article-details">
    @if (IsLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (Article == null)
    {
        <div class="alert alert-warning">
            Article not found. <a href="/">Return to Home</a>
        </div>
    }
    else
    {
        <article class="bg-white p-4 p-md-5 rounded shadow-sm border">
            <header class="mb-4">
                <h1 class="display-4 text-primary">@Article.Title</h1>
                <div class="text-muted">
                    <i class="bi bi-calendar"></i> @Article.CreatedDate.ToLongDateString()
                </div>
            </header>
            
            @if (!string.IsNullOrEmpty(Article.ImageUrl))
            {
                <div class="mb-4 text-center">
                    <img src="@Article.ImageUrl" class="img-fluid rounded" style="max-height: 500px;" alt="@Article.Title" />
                </div>
            }

            <div class="article-content fs-5" style="line-height: 1.8;">
                @((MarkupString)Article.Content)
            </div>

            <hr class="my-5" />
            
            <div class="text-center">
                <a href="/" class="btn btn-outline-primary">Back to Home</a>
            </div>
        </article>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private Article? Article;
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        Article = await ArticleService.GetArticleByIdAsync(Id);
        IsLoading = false;
        
        if (Article != null && !Article.IsVisible)
        {
            // If not visible, simulate not found (or allow admin to see it?)
            // For now, strictly hide.
            Article = null;
        }
    }
}
