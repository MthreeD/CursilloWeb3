@page "/page2"
@rendermode InteractiveServer
@using CursilloWeb.Data
@using Microsoft.EntityFrameworkCore
@using DevExpress.Blazor.Office
@using DevExpress.AIIntegration.Blazor.Editors
@using DevExpress.AIIntegration.Blazor

@inject ApplicationDbContext DbContext
@inject NavigationManager Navigation

<PageTitle>Page 2</PageTitle>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Page 2 - HTML Editor</h2>
        <div class="d-flex align-items-center" style="gap: 10px">
            @if (!IsLoading)
            {
                <DxButton Text="Save" 
                          RenderStyle="ButtonRenderStyle.Primary"
                          Click="@SaveData"
                          Enabled="@(!IsSaving)" />

                @if (IsSaving)
                {
                    <DxButton RenderStyle="ButtonRenderStyle.Secondary"
                              Enabled="false">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            Saving...
                    </DxButton>
                }
            }
            <DxButton Text="Cancel" 
                      CssClass="btn btn-outline-secondary"
                      Click="@NavigateToHome" />
        </div>
    </div>

    @if (IsLoading)
    {
        <DxLoadingPanel Visible="true" />
    }
    else
    {
        <div class="mb-3">
            <DxFormLayout>
                <DxFormLayoutItem Caption="HTML Content:" ColSpanMd="12">
                    <Template>
                        <div style="border: 1px solid #ccc;">
                            <DxHtmlEditor @bind-Markup="CurrentData.HTMLContents"
                                          Height="600px" 
                                          CssClass="w-100">
                                <Extensions>
                                    <DxHtmlEditorAIAssistant />
                                </Extensions>
                                <ChildContent>
                                    <DxHtmlEditorToolbar>
                                        <DxHtmlEditorToolbarGroup>
                                            <DxHtmlEditorAIAssistantToolbarItem />
                                        </DxHtmlEditorToolbarGroup>
                                    </DxHtmlEditorToolbar>
                                </ChildContent>
                            </DxHtmlEditor>
                        </div>
                    </Template>
                </DxFormLayoutItem>
            </DxFormLayout>
        </div>

        @if (!string.IsNullOrEmpty(Message))
        {
            <div class="mt-3">
                <div class="alert @(IsError ? "alert-danger" : "alert-success")" role="alert">
                    @Message
                    <button type="button" class="btn-close" data-bs-dismiss="alert" @onclick="@(() => Message = string.Empty)"></button>
                </div>
            </div>
        }
    }
</div>

@code {
    private Page2Data CurrentData = new Page2Data();
    private bool IsLoading = false;
    private bool IsSaving = false;
    private string Message = string.Empty;
    private bool IsError = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            IsLoading = true;
            var existingData = await DbContext.Page2s.FirstOrDefaultAsync();
            if (existingData != null)
            {
                CurrentData = existingData;
            }
        }
        catch (Exception ex)
        {
            Message = $"Error loading data: {ex.Message}";
            IsError = true;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task SaveData()
    {
        try
        {
            IsSaving = true;
            Message = string.Empty;

            if (CurrentData.Id == Guid.Empty)
            {
                CurrentData.Id = Guid.NewGuid();
                DbContext.Page2s.Add(CurrentData);
            }
            else
            {
                DbContext.Page2s.Update(CurrentData);
            }

            await DbContext.SaveChangesAsync();

            Message = "Data saved successfully!";
            IsError = false;
        }
        catch (Exception ex)
        {
            Message = $"Error saving data: {ex.Message}";
            IsError = true;
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void NavigateToHome()
    {
        Navigation.NavigateTo("/");
    }
}