@rendermode InteractiveServer
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@implements IDisposable

<header id="main-site-header" class="site-header d-flex justify-content-between align-items-center position-relative">
    <div class="header-content">
        @if (!string.IsNullOrEmpty(HeaderHtml))
        {
           @((MarkupString)HeaderHtml)
        }
        else
        {
            <div class="d-flex align-items-center">
                <!-- Placeholder Logo -->
                <span class="fs-3 fw-bold text-primary">Cursillo Venice Diocese</span>
            </div>
        }
    </div>

    <!-- Hamburger menu button positioned 10px from right, vertically centered, on top -->
    <div id="hamburger-menu-btn"
         class="position-absolute hamburger-container"
         style="right: 10px; top: 50%; transform: translateY(-50%); z-index: 1050;">
        <DxButton IconCssClass="bi bi-list fs-5"
                  RenderStyle="ButtonRenderStyle.None"
                  Click="ToggleFlyout"
                  title="Open Navigation Menu"
                  CssClass="hamburger-btn" />
    </div>
</header>

<!-- DxFlyout Control positioned to slide from left under hamburger menu -->
<DxFlyout @bind-IsOpen="isFlyoutOpen"
          PositionTarget="#hamburger-menu-btn"
          Placement="FlyoutPlacement.BottomLeft"
          Width="280px"
          CloseOnOutsideClick="true"
          CssClass="navigation-flyout">
    <BodyTextTemplate>
        <div class="navigation-menu-container">
            <div class="navigation-header">
                <h5 class="mb-0 text-white fw-bold">
                    Navigation Menu
                </h5>
            </div>
            <div class="navigation-content">
                <DxAccordion ExpandMode="AccordionExpandMode.SingleOrNone" 
                            CssClass="navigation-accordion">
                    <Items>
                        <DxAccordionItem Text="🏠 Home" 
                                        Click="@(() => NavigateAndClose("/"))" 
                                        CssClass="nav-item-home" />
                        <DxAccordionItem Text="📋 Test Page" 
                                        Click="@(() => NavigateAndClose("/test"))" 
                                        CssClass="nav-item-test" />
                        <DxAccordionItem Text="📁 Files"
                                        Click="@(() => NavigateAndClose("/file-upload"))" 
                                        CssClass="nav-item-files" />
                        <DxAccordionItem Text="⚙️ Webmaster Settings" CssClass="nav-item-webmaster">
                            <Items>
                                <DxAccordionItem Text="📥 File Download Settings" 
                                               Click="@(() => NavigateAndClose("/webmaster-settings"))" />
                            </Items>
                        </DxAccordionItem>
                        <DxAccordionItem Text="📰 Articles" CssClass="nav-item-articles">
                            <Items>
                                <DxAccordionItem Text="📖 View All" 
                                               Click="@(() => NavigateAndClose("/"))" />
                            </Items>
                        </DxAccordionItem>
                        <DxAccordionItem Text="⚙️ Admin & Editing" CssClass="nav-item-admin">
                            <Items>
                                <DxAccordionItem Text="🎛️ Dashboard" 
                                               Click="@(() => NavigateAndClose("/admin"))" />
                                <DxAccordionItem Text="📝 New Article" 
                                               Click="@(() => NavigateAndClose("/admin/article/new"))" />
                                <DxAccordionItem Text="🔧 Edit Header" 
                                               Click="@(() => NavigateAndClose("/admin/content/Header"))" />
                                <DxAccordionItem Text="🔧 Edit Footer" 
                                               Click="@(() => NavigateAndClose("/admin/content/Footer"))" />
                            </Items>
                        </DxAccordionItem>
                        <DxAccordionItem Text="🎨 Themes" CssClass="nav-item-themes">
                            <Items>
                                <DxAccordionItem Text="🍇 Blazing Berry" 
                                               Click="@(() => SwitchTheme("blazing-berry"))" />
                                <DxAccordionItem Text="🌙 Blazing Dark" 
                                               Click="@(() => SwitchTheme("blazing-dark"))" />
                                <DxAccordionItem Text="⚪ Office White" 
                                               Click="@(() => SwitchTheme("office-white"))" />
                                <DxAccordionItem Text="🟪 Purple" 
                                               Click="@(() => SwitchTheme("purple"))" />
                                <DxAccordionItem Text="⬜ Default" 
                                               Click="@(() => SwitchTheme("bootstrap-external"))" />
                            </Items>
                        </DxAccordionItem>
                    </Items>
                </DxAccordion>
            </div>
        </div>
    </BodyTextTemplate>
</DxFlyout>

<DxPopup @bind-Visible="TestPopupVisible"
         HeaderText="Test Popup"
         Width="400px"
         CloseOnOutsideClick="false">
    <BodyTemplate>
        <div class="p-3">
            <DxTextBox Text="testing it" 
                       ReadOnly="true" 
                       CssClass="mb-3" />
            <div class="mb-3">
                <strong>Current Date & Time:</strong>
                <div>@CurrentDateTime.ToString("F")</div>
            </div>
            <DxButton Text="Close" 
                      RenderStyle="ButtonRenderStyle.Primary" 
                      Click="@CloseTestPopup"
                      CssClass="w-100" />
        </div>
    </BodyTemplate>
</DxPopup>

@code {
    [Parameter]
    public string HeaderHtml { get; set; } = "";

    private bool TestPopupVisible = false;
    private DateTime CurrentDateTime = DateTime.Now;

    // Flyout state
    private bool isFlyoutOpen = false;

    protected override void OnInitialized()
    {
        // Subscribe to navigation changes to securely close menu when an item is chosen
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void ToggleFlyout()
    {
        isFlyoutOpen = !isFlyoutOpen;
    }

    private void NavigateAndClose(string url)
    {
        isFlyoutOpen = false;
        NavigationManager.NavigateTo(url);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (isFlyoutOpen)
        {
            isFlyoutOpen = false;
            InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    private void OpenTestPopup()
    {
        // Update the current date and time
        CurrentDateTime = DateTime.Now;

        // Open the popup
        TestPopupVisible = true;
    }

    private void CloseTestPopup()
    {
        TestPopupVisible = false;
    }

    private async Task SwitchTheme(string themeName)
    {
        await JSRuntime.InvokeVoidAsync("switchTheme", themeName);
    }
}
