@rendermode InteractiveServer
@inject NavigationManager NavigationManager
@implements IDisposable

<header id="main-site-header" class="site-header d-flex justify-content-between align-items-center position-relative">
    <div class="header-content">
        @if (!string.IsNullOrEmpty(HeaderHtml))
        {
           @((MarkupString)HeaderHtml)
        }
        else
        {
            <div class="d-flex align-items-center">
                <!-- Placeholder Logo -->
                <span class="fs-3 fw-bold text-primary">Cursillo Venice Diocese</span>
            </div>
        }
    </div>

    <!-- Hamburger menu button positioned 10px from right, vertically centered, on top -->
    <div id="hamburger-menu-btn"
         class="position-absolute"
         style="right: 10px; top: 50%; transform: translateY(-50%); z-index: 1050;">
        <DxButton IconCssClass="bi bi-list"
                  RenderStyle="ButtonRenderStyle.Secondary"
                  Click="ToggleFlyout" />
    </div>
</header>

<!-- DxFlyout Control placed right under the hamburger menu -->
<DxFlyout @bind-IsOpen="isFlyoutOpen"
          PositionTarget="#hamburger-menu-btn"
          Placement="FlyoutPlacement.Bottom"
          Width="250px"
          CloseOnOutsideClick="true">
    <BodyTextTemplate>
        <div class="p-3">
            <h5 class="mb-3 border-bottom pb-2 text-primary">Navigation Menu</h5>
            <DxAccordion ExpandMode="AccordionExpandMode.SingleOrNone">
                <Items>
                    <DxAccordionItem Text="Home" Click="@(() => NavigationManager.NavigateTo("/"))" />
                    <DxAccordionItem Text="Articles">
                        <Items>
                            <DxAccordionItem Text="View All" Click="@(() => NavigationManager.NavigateTo("/"))" />
                        </Items>
                    </DxAccordionItem>
                    <DxAccordionItem Text="Admin & Editing">
                        <Items>
                            <DxAccordionItem Text="Dashboard" Click="@(() => NavigationManager.NavigateTo("/admin"))" />
                            <DxAccordionItem Text="New Article" Click="@(() => NavigationManager.NavigateTo("/admin/article/new"))" />
                            <DxAccordionItem Text="Edit Header" Click="@(() => NavigationManager.NavigateTo("/admin/content/Header"))" />
                            <DxAccordionItem Text="Edit Footer" Click="@(() => NavigationManager.NavigateTo("/admin/content/Footer"))" />
                        </Items>
                    </DxAccordionItem>
                </Items>
            </DxAccordion>
        </div>
    </BodyTextTemplate>
</DxFlyout>

<DxPopup @bind-Visible="TestPopupVisible"
         HeaderText="Test Popup"
         Width="400px"
         CloseOnOutsideClick="false">
    <BodyTemplate>
        <div class="p-3">
            <DxTextBox Text="testing it" 
                       ReadOnly="true" 
                       CssClass="mb-3" />
            <div class="mb-3">
                <strong>Current Date & Time:</strong>
                <div>@CurrentDateTime.ToString("F")</div>
            </div>
            <DxButton Text="Close" 
                      RenderStyle="ButtonRenderStyle.Primary" 
                      Click="@CloseTestPopup"
                      CssClass="w-100" />
        </div>
    </BodyTemplate>
</DxPopup>

@code {
    [Parameter]
    public string HeaderHtml { get; set; } = "";

    private bool TestPopupVisible = false;
    private DateTime CurrentDateTime = DateTime.Now;

    // Flyout state
    private bool isFlyoutOpen = false;

    protected override void OnInitialized()
    {
        // Subscribe to navigation changes to securely close menu when an item is chosen
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void ToggleFlyout()
    {
        isFlyoutOpen = !isFlyoutOpen;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (isFlyoutOpen)
        {
            isFlyoutOpen = false;
            InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    private void OpenTestPopup()
    {
        // Update the current date and time
        CurrentDateTime = DateTime.Now;

        // Open the popup
        TestPopupVisible = true;
    }

    private void CloseTestPopup()
    {
        TestPopupVisible = false;
    }
}
