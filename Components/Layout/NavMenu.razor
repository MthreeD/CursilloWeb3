@implements IDisposable

@inject NavigationManager NavigationManager

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">CursilloWeb</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="counter">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Counter
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="weather">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Weather
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="test">
                <span class="bi bi-gear-fill-nav-menu" aria-hidden="true"></span> Test Page
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="file-upload">
                <span class="bi bi-file-earmark-arrow-up-nav-menu" aria-hidden="true"></span> File Upload
            </NavLink>
        </div>

        @* Administration Dropdown *@
        <div class="nav-item px-3">
            <button class="btn btn-toggle nav-link d-flex align-items-center w-100 text-start" 
                    @onclick="ToggleAdminMenu">
                <span class="bi bi-shield-lock-fill me-2" aria-hidden="true"></span> 
                Administration
                <span class="bi @(IsAdminMenuExpanded ? "bi-chevron-down" : "bi-chevron-right") ms-auto"></span>
            </button>
            @if (IsAdminMenuExpanded)
            {
                <div class="ps-4">
                    <NavLink class="nav-link" href="admin">
                        <span class="bi bi-speedometer2" aria-hidden="true"></span> Dashboard
                    </NavLink>
                    <NavLink class="nav-link" href="admin/article/new">
                        <span class="bi bi-file-earmark-plus" aria-hidden="true"></span> New Article
                    </NavLink>
                    <NavLink class="nav-link" href="admin/content/Header">
                        <span class="bi bi-layout-text-window-reverse" aria-hidden="true"></span> Edit Header
                    </NavLink>
                    <NavLink class="nav-link" href="admin/content/Footer">
                        <span class="bi bi-layout-text-window" aria-hidden="true"></span> Edit Footer
                    </NavLink>
                    <NavLink class="nav-link" href="admin/settings">
                        <span class="bi bi-gear-fill" aria-hidden="true"></span> Application Settings
                    </NavLink>
                </div>
            }
        </div>
    </nav>
</div>

@code {
    private bool IsAdminMenuExpanded = false;

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    private void ToggleAdminMenu()
    {
        IsAdminMenuExpanded = !IsAdminMenuExpanded;
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}

