@inherits LayoutComponentBase
@inject CursilloWeb.Services.ContentService ContentService

<div class="page-container">
    <header class="site-header d-flex justify-content-between align-items-center">
        <div class="header-content">
            @if (!string.IsNullOrEmpty(HeaderHtml))
            {
               @((MarkupString)HeaderHtml)
            }
            else
            {
                <div class="d-flex align-items-center">
                    <!-- Placeholder Logo -->
                    <span class="fs-3 fw-bold text-primary">Cursillo Venice Diocese</span>
                </div>
            }
        </div>
        
        <HeaderMenu @rendermode="InteractiveServer" />
    </header>

    <main class="container my-4">
        @Body
    </main>

    <footer class="site-footer">
        <div class="container">
            @if (!string.IsNullOrEmpty(FooterHtml))
            {
                @((MarkupString)FooterHtml)
            }
            else
            {
                <p class="text-center mb-0">&copy; @DateTime.Now.Year - Cursillo Venice Diocese</p>
            }
        </div>
    </footer>
</div>

@code {
    private string HeaderHtml = "";
    private string FooterHtml = "";

    protected override async Task OnInitializedAsync()
    {
        HeaderHtml = await ContentService.GetContentAsync("Header");
        FooterHtml = await ContentService.GetContentAsync("Footer");
    }
}
