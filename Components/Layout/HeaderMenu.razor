@using DevExpress.Blazor
@inject NavigationManager NavigationManager
@implements IDisposable

<DxButton id="hamburger"
          RenderStyle="ButtonRenderStyle.Primary"
          RenderStyleMode="ButtonRenderStyleMode.Outline"
          IconCssClass="bi bi-list fs-4"
          Click="@(() => isFlyoutOpen = !isFlyoutOpen)" />

<DxFlyout @bind-IsOpen="@isFlyoutOpen"
          PositionTarget="#hamburger"
          Placement="FlyoutPlacement.BottomEnd"
          Width="300px">
    <BodyTemplate>
        <div class="p-3">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Navigation Menu</h5>
                <DxButton RenderStyle="ButtonRenderStyle.Danger"
                          RenderStyleMode="ButtonRenderStyleMode.Contained"
                          IconCssClass="bi bi-x-lg"
                          Click="@(() => isFlyoutOpen = false)" />
            </div>
            <div class="d-flex flex-column gap-2 mb-3">
                <DxButton NavigateUrl="/" 
                          RenderStyle="ButtonRenderStyle.Secondary"
                          RenderStyleMode="ButtonRenderStyleMode.Text"
                          IconCssClass="bi bi-house" 
                          Text="Home" 
                          CssClass="text-start justify-content-start" />
                <AuthorizeView>
                    <Authorized Context="authContext">
                        <DxButton NavigateUrl="admin/users" 
                                  RenderStyle="ButtonRenderStyle.Secondary"
                                  RenderStyleMode="ButtonRenderStyleMode.Text"
                                  IconCssClass="bi bi-people" 
                                  Text="Users" 
                                  CssClass="text-start justify-content-start" />
                        <DxButton NavigateUrl="admin/roles" 
                                  RenderStyle="ButtonRenderStyle.Secondary"
                                  RenderStyleMode="ButtonRenderStyleMode.Text"
                                  IconCssClass="bi bi-shield-lock" 
                                  Text="Roles" 
                                  CssClass="text-start justify-content-start" />
                    </Authorized>
                    <NotAuthorized Context="authContext">
                        <DxButton RenderStyle="ButtonRenderStyle.Secondary"
                                  RenderStyleMode="ButtonRenderStyleMode.Text"
                                  IconCssClass="bi bi-key" 
                                  Text="Log In" 
                                  CssClass="text-start justify-content-start"
                                  Click="@(() => { isLoginOpen = true; isFlyoutOpen = false; })" />
                    </NotAuthorized>
                </AuthorizeView>
            </div>

            <DxAccordion ExpandMode="AccordionExpandMode.SingleOrNone">
                <Items>
                    <DxAccordionItem Text="Theme Switcher">
                        <ContentTemplate Context="themeContext">
                            <ThemeSwitcher />
                        </ContentTemplate>
                    </DxAccordionItem>
                </Items>
            </DxAccordion>
        </div>
    </BodyTemplate>
</DxFlyout>

<CursilloWeb.Components.Account.LoginPopup @bind-IsOpen="isLoginOpen" HasError="@hasLoginError" />

@code {
    [SupplyParameterFromQuery]
    [Parameter]
    public bool LoginFailed { get; set; }

    private bool isFlyoutOpen = false;
    private bool isLoginOpen = false;
    private bool hasLoginError = false;

    protected override void OnInitialized()
    {
        if (LoginFailed)
        {
            isLoginOpen = true;
            hasLoginError = true;
        }

        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (isFlyoutOpen)
        {
            isFlyoutOpen = false;
            InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
