<body>
    <Routes />
    <ReconnectModal />
    <script src="_content/DevExpress.Blazor/dx-blazor.js"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    <script>
        window.quillInterop = {
            createEditor: function(elementId, initialContent, dotNetReference) {
                var quill = new Quill('#' + elementId, {
                    theme: 'snow',
                    modules: {
                        toolbar: [
                            ['bold', 'italic', 'underline', 'strike'],
                            ['blockquote', 'code-block'],
                            [{ 'header': 1 }, { 'header': 2 }],
                            [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                            [{ 'color': [] }, { 'background': [] }],
                            ['link', 'image']
                        ]
                    }
                });
                if (initialContent) {
                    quill.root.innerHTML = initialContent;
                }
                quill.on('text-change', function() {
                    var html = quill.root.innerHTML;
                    dotNetReference.invokeMethodAsync('UpdateContent', html);
                });
            }
        };
    </script>
    <script src="@Assets["Components/Account/Shared/PasskeySubmit.razor.js"]" type="module"></script>
</body>

</html>
