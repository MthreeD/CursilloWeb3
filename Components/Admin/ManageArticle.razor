@page "/admin/article/new"
@page "/admin/article/{Id:guid}"
@using Microsoft.AspNetCore.Authorization
@using CursilloWeb.Data
@attribute [Authorize]
@inject CursilloWeb.Services.ArticleService ArticleService
@inject NavigationManager Navigation

<PageTitle>@(Id == null || Id == Guid.Empty ? "New Article" : "Edit Article")</PageTitle>

<div class="container">
    <div class="row align-items-center mb-4">
        <div class="col">
            <h2>@(Id == null || Id == Guid.Empty ? "Create Article" : "Edit Article")</h2>
        </div>
        <div class="col-auto">
             <a href="/admin" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </div>

    @if (ArticleModel == null)
    {
        <p>Loading...</p>
    }
    else
    {
        <EditForm Model="ArticleModel" OnValidSubmit="SaveArticle">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Title</label>
                <InputText @bind-Value="ArticleModel.Title" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Image URL</label>
                <InputText @bind-Value="ArticleModel.ImageUrl" class="form-control" placeholder="https://..." />
            </div>
            
            <div class="mb-3 form-check">
                <InputCheckbox @bind-Value="ArticleModel.IsVisible" class="form-check-input" id="isVisible" />
                <label class="form-check-label" for="isVisible">Visible to Public</label>
            </div>

            <div class="mb-3">
                <label class="form-label">Content</label>
                <RichTextEditor @bind-Content="ArticleModel.Content" />
            </div>

            <button type="submit" class="btn btn-primary">Save Article</button>
        </EditForm>
    }
</div>

@code {
    [Parameter] public Guid? Id { get; set; }

    private Article? ArticleModel;

    protected override async Task OnInitializedAsync()
    {
        if (Id == null || Id == Guid.Empty)
        {
            ArticleModel = new Article();
        }
        else
        {
            ArticleModel = await ArticleService.GetArticleByIdAsync(Id.Value);
            if (ArticleModel == null)
            {
                Navigation.NavigateTo("/admin");
            }
        }
    }

    private async Task SaveArticle()
    {
        if (ArticleModel == null) return;

        if (Id == null || Id == Guid.Empty)
        {
            await ArticleService.CreateArticleAsync(ArticleModel);
        }
        else
        {
            await ArticleService.UpdateArticleAsync(ArticleModel);
        }
        Navigation.NavigateTo("/admin");
    }
}
