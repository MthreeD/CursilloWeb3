@page "/admin"
@rendermode InteractiveServer
@* @using Microsoft.AspNetCore.Authorization *@
@using CursilloWeb.Data

@* @attribute [Authorize] *@
@inject CursilloWeb.Services.ArticleService ArticleService

<PageTitle>Admin Dashboard</PageTitle>

<div class="row mb-4">
    <div class="col">
        <h1>Admin Dashboard</h1>
    </div>
    <div class="col-auto">
        <DxButton Text="New Article" 
                  IconCssClass="bi bi-plus-lg" 
                  RenderStyle="ButtonRenderStyle.Primary"
                  Click="@(() => Navigation.NavigateTo("admin/article/new"))" />
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Site Content</h5>
            </div>
            <div class="card-body">
                <p>Manage global sections like Header and Footer.</p>
                <DxButton Text="Edit Header" 
                          RenderStyle="ButtonRenderStyle.Secondary" 
                          Click="@(() => Navigation.NavigateTo("admin/content/Header"))"
                          CssClass="me-2 mb-2" />
                <DxButton Text="Edit Footer (Basic)" 
                          RenderStyle="ButtonRenderStyle.Secondary" 
                          Click="@(() => Navigation.NavigateTo("admin/content/Footer"))"
                          CssClass="me-2 mb-2" />
                <DxButton Text="Edit New Footer" 
                          RenderStyle="ButtonRenderStyle.Secondary" 
                          Click="@(() => Navigation.NavigateTo("admin/newfooteredit"))"
                          CssClass="me-2 mb-2" />
                <br />
                <DxButton Text="Manage Footer (Advanced)" 
                          RenderStyle="ButtonRenderStyle.Primary" 
                          RenderStyleMode="ButtonRenderStyleMode.Outline"
                          IconCssClass="bi bi-gear"
                          Click="@(() => Navigation.NavigateTo("admin/manage-footer"))"
                          CssClass="me-2" />
                <small class="text-muted d-block mt-1">Full footer management with live preview and templates</small>
            </div>
        </div>
    </div>
    <div class="col-md-6">
         <!-- Placeholder for other admin tasks -->
    </div>
</div>

<h3 class="mb-3">Articles</h3>

@if (Articles == null)
{
    <DxLoadingPanel Visible="true" />
}
else
{
    <DxGrid Data="@Articles" 
            CssClass="my-grid"
            PageSize="10"
            ShowPager="true"
            PagerNavigationMode="PagerNavigationMode.NumericButtons"
            PagerSwitchToInputBoxButtonCount="5"
            EditMode="GridEditMode.PopupEditForm">
        <Columns>
            <DxGridDataColumn FieldName="Title" Caption="Title" />
            <DxGridDataColumn FieldName="CreatedDate" Caption="Date" DisplayFormat="{0:d}" />
            <DxGridDataColumn FieldName="IsVisible" Caption="Visible">
                <CellDisplayTemplate>
                    @{
                        var article = (Article)context.DataItem;
                        if (article.IsVisible)
                        {
                            <span class="badge bg-success">Visible</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Hidden</span>
                        }
                    }
                </CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridCommandColumn Width="200px">
                <HeaderCaptionTemplate>Actions</HeaderCaptionTemplate>
                <CellDisplayTemplate>
                    @{
                        var article = (Article)context.DataItem;
                        <DxButton Text="Edit" 
                                  IconCssClass="bi bi-pencil" 
                                  RenderStyle="ButtonRenderStyle.Primary" 
                                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                                  Click="@(() => Navigation.NavigateTo($"admin/article/{article.Id}"))"
                                  CssClass="me-2" />
                        <DxButton Text="Delete" 
                                  IconCssClass="bi bi-trash" 
                                  RenderStyle="ButtonRenderStyle.Danger" 
                                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                                  Click="@(() => DeleteArticle(article.Id))" />
                    }
                </CellDisplayTemplate>
            </DxGridCommandColumn>
        </Columns>
    </DxGrid>
}

@code {
    private List<Article>? Articles;

    protected override async Task OnInitializedAsync()
    {
        await LoadArticles();
    }

    private async Task LoadArticles()
    {
        Articles = await ArticleService.GetArticlesAsync(onlyVisible: false);
    }

    private async Task DeleteArticle(Guid id)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this article?"))
        {
            await ArticleService.DeleteArticleAsync(id);
            await LoadArticles();
        }
    }

    [Inject] public required IJSRuntime JSRuntime { get; set; }
    [Inject] public required NavigationManager Navigation { get; set; }
}
