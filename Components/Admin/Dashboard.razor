@page "/admin"
@using Microsoft.AspNetCore.Authorization
@using CursilloWeb.Data
@attribute [Authorize]
@inject CursilloWeb.Services.ArticleService ArticleService

<PageTitle>Admin Dashboard</PageTitle>

<div class="row mb-4">
    <div class="col">
        <h1>Admin Dashboard</h1>
    </div>
    <div class="col-auto">
        <a href="admin/article/new" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> New Article
        </a>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Site Content</h5>
                <p>Manage global sections like Header and Footer.</p>
                <a href="admin/content/Header" class="btn btn-outline-secondary">Edit Header</a>
                <a href="admin/content/Footer" class="btn btn-outline-secondary">Edit Footer</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
         <!-- Placeholder for other admin tasks -->
    </div>
</div>

<h3 class="mb-3">Articles</h3>

@if (Articles == null)
{
    <p>Loading...</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Date</th>
                    <th>Visible</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var article in Articles)
                {
                    <tr>
                        <td>@article.Title</td>
                        <td>@article.CreatedDate.ToShortDateString()</td>
                        <td>
                            @if (article.IsVisible)
                            {
                                <span class="badge bg-success">Visible</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Hidden</span>
                            }
                        </td>
                        <td>
                            <a href="admin/article/@article.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteArticle(article.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Article>? Articles;

    protected override async Task OnInitializedAsync()
    {
        await LoadArticles();
    }

    private async Task LoadArticles()
    {
        Articles = await ArticleService.GetArticlesAsync(onlyVisible: false);
    }

    private async Task DeleteArticle(int id)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this article?"))
        {
            await ArticleService.DeleteArticleAsync(id);
            await LoadArticles();
        }
    }
    
    [Inject] IJSRuntime JSRuntime { get; set; }
}
