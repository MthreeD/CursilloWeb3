@page "/admin/content/{Section}"
@rendermode InteractiveServer
@using DevExpress.Blazor.RichEdit
@using CursilloWeb.Data
@inject CursilloWeb.Services.ContentService ContentService
@inject NavigationManager Navigation

<PageTitle>Edit @Section</PageTitle>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Edit @Section</h2>
        <a href="/admin" class="btn btn-outline-secondary">Back to Dashboard</a>
    </div>

    @if (IsLoading)
    {
        <p>Loading...</p>
    }
    else
    {
        <div class="mb-4">
            <div class="alert alert-info">
                Use the editor below to customize the @Section content.
            </div>

            <DxRichEdit @ref="richEdit"
                        @bind-DocumentContent="FileContent" 
                        DocumentFormat="DevExpress.Blazor.RichEdit.DocumentFormat.Rtf" 
                        Height="600px" 
                        CssClass="w-100" />
        </div>

        <button class="btn btn-primary" @onclick="SaveContent">Save Content</button>
    }
</div>

@code {
    [Parameter] public string Section { get; set; } = "Header";

    private DxRichEdit? richEdit;
    private byte[] FileContent = Array.Empty<byte>();
    private bool IsLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        IsLoading = true;
        string content = await ContentService.GetRichTextContentAsync(Section);
        if (!string.IsNullOrEmpty(content))
        {
            FileContent = System.Text.Encoding.UTF8.GetBytes(content);
        }
        else 
        {
            // If RichTextContent is empty, try getting HtmlContent as fallback
            string htmlContent = await ContentService.GetContentAsync(Section);
            if (!string.IsNullOrEmpty(htmlContent)) 
            {
                FileContent = System.Text.Encoding.UTF8.GetBytes(htmlContent);
            }
        }
        IsLoading = false;
    }

    private async Task SaveContent()
    {
        if (richEdit != null)
        {
            await richEdit.SaveDocumentAsync();
        }
        string richTextContent = System.Text.Encoding.UTF8.GetString(FileContent);
        await ContentService.UpdateRichTextContentAsync(Section, richTextContent);
        Navigation.NavigateTo("/admin");
    }
}
