@using DevExpress.Blazor

<DxHtmlEditor @bind-Markup="Content"
             Height="300px"
             Width="100%"
             @bind-Markup:after="OnContentChanged">
    <DxHtmlEditorToolbar>
        <DxHtmlEditorBoldButton />
        <DxHtmlEditorItalicButton />
        <DxHtmlEditorUnderlineButton />
        <DxHtmlEditorSeparator />
        <DxHtmlEditorAlignLeftButton />
        <DxHtmlEditorAlignCenterButton />
        <DxHtmlEditorAlignRightButton />
        <DxHtmlEditorSeparator />
        <DxHtmlEditorBulletedListButton />
        <DxHtmlEditorNumberedListButton />
        <DxHtmlEditorSeparator />
        <DxHtmlEditorUndoButton />
        <DxHtmlEditorRedoButton />
    </DxHtmlEditorToolbar>
</DxHtmlEditor>

@code {
    [Parameter] public string Content { get; set; } = "";
    [Parameter] public EventCallback<string> ContentChanged { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // This is called only on the first render - NO JavaScript needed!
            Console.WriteLine("DxHtmlEditor first render completed");

            // Any other first-render initialization goes here
            await InitializeEditor();
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private async Task InitializeEditor()
    {
        // Custom initialization logic for first render
        await Task.CompletedTask;
    }

    private async Task OnContentChanged()
    {
        await ContentChanged.InvokeAsync(Content);
    }
}
